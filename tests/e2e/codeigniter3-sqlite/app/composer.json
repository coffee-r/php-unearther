{
  "name": "coffee-r/php-ci3-unearth-sqlite-fixture",
  "description": "CodeIgniter3 SQLite e2e fixture for php-ci3-unearth.",
  "type": "project",
  "repositories": [
    {
      "type": "path",
      "url": "/workspace/php-ci3-unearth",
      "options": {
        "symlink": false
      }
    }
  ],
  "require": {
    "php": ">=7.3",
    "codeigniter/framework": "^3.1",
    "coffee-r/php-ci3-unearth": "*",
    "guzzlehttp/guzzle": "^7.4"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
