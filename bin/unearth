#!/usr/bin/env php
<?php

use CoffeeR\Unearth\Report\Aggregator;
use CoffeeR\Unearth\Export\RedactedExporter;
use CoffeeR\Unearth\Report\JsonlReader;
use CoffeeR\Unearth\Report\MarkdownRenderer;

$autoloadPaths = array();
if (isset($_composer_autoload_path)) {
    $autoloadPaths[] = $_composer_autoload_path;
}
$autoloadPaths[] = __DIR__ . '/../vendor/autoload.php';
$autoloadPaths[] = __DIR__ . '/../../../autoload.php';

$autoloaded = false;
foreach ($autoloadPaths as $autoloadPath) {
    if (is_file($autoloadPath)) {
        require_once $autoloadPath;
        $autoloaded = true;
        break;
    }
}

if (!$autoloaded) {
    fwrite(STDERR, "Unable to find Composer autoload.php. Run composer install first.\n");
    exit(1);
}

$argv = $_SERVER['argv'];
array_shift($argv);

$command = array_shift($argv);
if ($command !== 'report' && $command !== 'export') {
    fwrite(STDERR, "Usage: unearth report <jsonl...> --format md|markdown|json [--value-mode normalized|tokenized|raw] [--table-catalog catalog.json]\n");
    fwrite(STDERR, "       unearth export <jsonl...> --profile ai --format jsonl|json\n");
    exit(1);
}

$format = 'md';
$profile = 'ai';
$valueMode = 'normalized';
$tableCatalogPath = null;
$paths = array();
for ($i = 0; $i < count($argv); $i++) {
    if ($argv[$i] === '--format' && isset($argv[$i + 1])) {
        $format = $argv[$i + 1];
        $i++;
        continue;
    }
    if ($argv[$i] === '--profile' && isset($argv[$i + 1])) {
        $profile = $argv[$i + 1];
        $i++;
        continue;
    }
    if ($argv[$i] === '--value-mode' && isset($argv[$i + 1])) {
        $valueMode = $argv[$i + 1];
        $i++;
        continue;
    }
    if ($argv[$i] === '--table-catalog' && isset($argv[$i + 1])) {
        $tableCatalogPath = $argv[$i + 1];
        $i++;
        continue;
    }

    $paths[] = $argv[$i];
}

if (count($paths) === 0) {
    fwrite(STDERR, "No JSONL files given.\n");
    exit(1);
}

$reader = new JsonlReader();
$traces = $reader->read($paths);
foreach ($reader->warnings() as $warning) {
    fwrite(STDERR, "Warning: " . $warning . "\n");
}

if ($command === 'export') {
    if ($profile !== 'ai') {
        fwrite(STDERR, "Unknown export profile: " . $profile . "\n");
        exit(1);
    }
    $exporter = new RedactedExporter();
    $exported = $exporter->export($traces);

    if ($format === 'json') {
        echo json_encode($exported, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n";
        exit(0);
    }
    if ($format === 'jsonl') {
        foreach ($exported as $trace) {
            echo json_encode($trace, JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n";
        }
        exit(0);
    }

    fwrite(STDERR, "Unknown format: " . $format . "\n");
    exit(1);
}

$tableCatalog = array();
if ($tableCatalogPath !== null) {
    if (!is_file($tableCatalogPath)) {
        fwrite(STDERR, "Table catalog file not found: " . $tableCatalogPath . "\n");
        exit(1);
    }
    $decoded = json_decode(file_get_contents($tableCatalogPath), true);
    if (!is_array($decoded) || (count($decoded) > 0 && array_keys($decoded) === range(0, count($decoded) - 1))) {
        fwrite(STDERR, "Invalid table catalog JSON: " . $tableCatalogPath . "\n");
        exit(1);
    }
    $tableCatalog = $decoded;
}

$aggregator = new Aggregator($valueMode, $tableCatalog);
$report = $aggregator->aggregate($traces);

if ($format === 'json') {
    echo json_encode($report, JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES | JSON_UNESCAPED_UNICODE) . "\n";
    exit(0);
}

if ($format === 'md' || $format === 'markdown') {
    $renderer = new MarkdownRenderer();
    echo $renderer->render($report);
    exit(0);
}

fwrite(STDERR, "Unknown format: " . $format . "\n");
exit(1);
