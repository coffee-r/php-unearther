{
  "name": "coffee-r/php-ci3-unearth",
  "description": "Observed behavior reporting for CodeIgniter3 application migrations.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=7.3"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12",
    "phpunit/phpunit": "^9.6"
  },
  "suggest": {
    "guzzlehttp/guzzle": "Use the optional Guzzle middleware for external HTTP observation."
  },
  "autoload": {
    "psr-4": {
      "CoffeeR\\Ci3Unearth\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CoffeeR\\Ci3Unearth\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/unearth"
  ],
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse --debug",
    "e2e:ci3-sqlite": "bash tests/e2e/codeigniter3-sqlite/scripts/run.sh",
    "e2e:ci3-pg": "bash tests/e2e/codeigniter3-postgresql/scripts/run.sh"
  }
}
