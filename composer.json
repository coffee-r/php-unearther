{
  "name": "coffee-r/php-unearth",
  "description": "Observed behavior reporting for legacy PHP API migrations.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=7.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6"
  },
  "suggest": {
    "guzzlehttp/guzzle": "Use the optional Guzzle middleware for external HTTP observation."
  },
  "autoload": {
    "psr-4": {
      "CoffeeR\\Unearth\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CoffeeR\\Unearth\\Tests\\": "tests/"
    }
  },
  "bin": [
    "bin/unearth"
  ],
  "scripts": {
    "test": "phpunit",
    "e2e:ci3-sqlite": "bash tests/e2e/codeigniter3-sqlite/scripts/run.sh"
  }
}
